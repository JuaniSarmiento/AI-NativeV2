# ==================================
# Plataforma AI-Native — Environment Variables
# ==================================
# Copy to .env and fill with local values.
# NEVER commit .env — it's in .gitignore.

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING

# --- Backend (FastAPI) ---
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
BACKEND_WORKERS=1

# --- Frontend (Vite) ---
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://ainative:ainative@localhost:5432/ainative
POSTGRES_USER=ainative
POSTGRES_PASSWORD=ainative
POSTGRES_DB=ainative
POSTGRES_PORT=5432

# --- Cache (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT ---
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Anthropic API (Tutor Socrático) ---
ANTHROPIC_API_KEY=CHANGE_ME
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1024

# --- Sandbox (Ejecución de código) ---
SANDBOX_TIMEOUT_SECONDS=10
SANDBOX_MEMORY_LIMIT_MB=128
SANDBOX_NETWORK_ACCESS=false

# --- Rate Limiting ---
RATE_LIMIT_TUTOR=30/hour
RATE_LIMIT_GENERAL=100/minute

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_FORMAT=json
